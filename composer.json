{
    "name": "zeeshanmushtq/apinexa",
    "version": "1.0.4",
    "description": "File-first API schema engine for Laravel with runtime registry, OpenAPI generation and signed API keys.",
    "keywords": [
        "laravel",
        "api",
        "openapi",
        "documentation",
        "api-keys",
        "schema",
        "apinexa"
    ],
    "license": "MIT",
    "type": "library",
    "homepage": "https://github.com/Zeeshan12378/laravel-apinexa",
    "authors": [
        {
            "name": "Zeeshan Mushtaq Joyia",
            "email": "zeeshamushtaqdev786@gmail.com"
        }
    ],
    "support": {
        "issues": "https://github.com/Zeeshan12378/laravel-apinexa/issues",
        "source": "https://github.com/Zeeshan12378/laravel-apinexa"
    },
    "require": {
        "php": "^8.3",
        "illuminate/cache": "^11.0|^12.0",
        "illuminate/console": "^11.0|^12.0",
        "illuminate/contracts": "^11.0|^12.0",
        "illuminate/filesystem": "^11.0|^12.0",
        "illuminate/http": "^11.0|^12.0",
        "illuminate/support": "^11.0|^12.0"
    },
    "require-dev": {
        "orchestra/testbench": "^9.0|^10.0",
        "phpunit/phpunit": "^11.5"
    },
    "autoload": {
        "psr-4": {
            "ZeeshanMushtaq\\ApiNexa\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "ZeeshanMushtaq\\ApiNexa\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "ZeeshanMushtaq\\ApiNexa\\ApiNexaServiceProvider"
            ]
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true,
    "config": {
        "sort-packages": true,
        "optimize-autoloader": true
    },
    "scripts": {
        "test": "vendor/bin/phpunit"
    }
}