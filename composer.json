{
    "name": "zeeshanmushtq/apinexa",
    "version": "1.0.0",
    "description": "File-first API schema engine for Laravel — registry, docs, and signed API keys.",
    "keywords": [
        "laravel",
        "api",
        "openapi",
        "documentation",
        "api-keys",
        "schema"
    ],
    "license": "MIT",
    "type": "library",
    "authors": [
        {
            "name": "Zeeshan Mushtaq Joyia",
            "email": "zeeshamushtaqdev786@gmail.com"
        }
    ],
    "require": {
        "php": "^8.3",
        "illuminate/cache": "^11.0|^12.0",
        "illuminate/console": "^11.0|^12.0",
        "illuminate/contracts": "^11.0|^12.0",
        "illuminate/filesystem": "^11.0|^12.0",
        "illuminate/http": "^11.0|^12.0",
        "illuminate/support": "^11.0|^12.0"
    },
    "require-dev": {
        "orchestra/testbench": "^9.0|^10.0",
        "phpunit/phpunit": "^11.0"
    },
    "autoload": {
        "psr-4": {
            "ZeeshanMushtaq\\APINEXA\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "ZeeshanMushtaq\\APINEXA\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "ZeeshanMushtaq\\APINEXA\\APINEXAServiceProvider"
            ],
            "aliases": {
                "APINEXA": "ZeeshanMushtaq\\APINEXA\\Facades\\APINEXA"
            }
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true,
    "config": {
        "sort-packages": true
    },
    "scripts": {
        "test": "phpunit"
    }
}
